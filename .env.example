OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
APIMART_API_KEY=sk-your-apimart-key-here
APIMART_BASE_URL=https://api.apimart.ai/api/v1
# Optional: route OpenRouter requests through an overseas HTTP/HTTPS proxy.
# Example: OPENROUTER_PROXY_URL=http://127.0.0.1:7890
# Example: OPENROUTER_PROXY_URL=http://user:password@your-vps-ip:port
OPENROUTER_PROXY_URL=

# Pick OpenRouter model ids from https://openrouter.ai/models
MODEL_GPT=gpt-5.5
MODEL_GPT_LABEL=GPT 5.5
MODEL_GPT_PROVIDER=openai
MODEL_CLAUDE=claude-opus-4-8
MODEL_CLAUDE_LABEL=Claude 4.8
MODEL_CLAUDE_PROVIDER=apimart
MODEL_GEMINI=gemini-3.1-pro-preview
MODEL_GEMINI_LABEL=Gemini
MODEL_GEMINI_PROVIDER=apimart
MODEL_DEEPSEEK=deepseek/deepseek-v4-pro
MODEL_QWEN=qwen/qwen3.7-max

PORT=3888

# Cloudflare Worker / Supabase backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-public-key
GUEST_USAGE_SECRET=replace-with-a-long-random-secret
AUTH_SITE_URL=https://futbots.cc
TELEGRAM_AUTH_ENABLED=false
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_PROXY_SECRET=
API_FOOTBALL_LEAGUES=1,15,17,39,140,78,135,61,2,3,188,307,169,170,171
ALLSCALE_API_KEY=your-allscale-api-key
ALLSCALE_API_SECRET=your-allscale-api-secret
ALLSCALE_BASE_URL=https://openapi.allscale.io
# Legacy projects can use SUPABASE_ANON_KEY instead.
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=sb_secret_your-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
