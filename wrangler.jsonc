{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "football-fraud-ai",
  "main": "worker/index.js",
  "compatibility_date": "2026-06-25",
  "triggers": {
    "crons": ["*/20 * * * *"]
  },
  "routes": [
    {
      "pattern": "futbots.cc",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "vars": {
    "OPENROUTER_BASE_URL": "https://openrouter.ai/api/v1",
    "OPENAI_BASE_URL": "https://api.openai.com/v1",
    "APIMART_BASE_URL": "https://api.apimart.ai/api/v1",
    "ALLSCALE_BASE_URL": "https://openapi.allscale.io",
    "AUTH_SITE_URL": "https://futbots.cc",
    "TELEGRAM_AUTH_ENABLED": "true",
    "API_FOOTBALL_BASE_URL": "https://api-football-proxy.64-186-226-161.sslip.io",
    "API_FOOTBALL_LEAGUES": "1,15,17,39,140,78,135,61,2,3,188,307,169,170,171",
    "API_FOOTBALL_DAILY_LIMIT": "7500",
    "MODEL_GPT": "gpt-5.5",
    "MODEL_GPT_PROVIDER": "openai",
    "MODEL_GPT_LABEL": "GPT 5.5",
    "MODEL_CLAUDE_PROVIDER": "apimart",
    "MODEL_CLAUDE_LABEL": "Claude 4.8",
    "MODEL_GEMINI_PROVIDER": "apimart",
    "MODEL_GEMINI_LABEL": "Gemini",
    "MODEL_DEEPSEEK_LABEL": "DeepSeek",
    "MODEL_QWEN": "qwen/qwen3.7-max",
    "MODEL_QWEN_LABEL": "Qwen 3.7 Max"
  }
}
